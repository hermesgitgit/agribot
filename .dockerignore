# 不要烤進映像檔的東西：
# data/ 是執行期 volume（SQLite、照片、心跳檔），映像檔裡不該有一份舊快照
data/
# 舊單檔備份與本機測試工具
*.bak
baseline_names.txt
import_test.sh
# 祕密
.env
.env.*
*.secret
# 版控與作業系統中繼資料：不該進 build context（.git 會隨每次部署快照長大、拖慢 build）
.git/
.gitignore
__pycache__/
*.pyc
.DS_Store
# Synology Drive / NAS 同步中繼資料
.SynologyWorkingDirectory/
@eaDir/
*.SynoEAStream
*.SynoResource
# macOS 專用編譯產物（容器用不到）
scripts/ocr_pdf
